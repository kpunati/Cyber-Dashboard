# Upstash Redis Configuration (for production caching)
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Alternative: Vercel KV (if deploying to Vercel)
# KV_URL=your_vercel_kv_url_here
# KV_REST_API_URL=your_vercel_kv_rest_api_url_here
# KV_REST_API_TOKEN=your_vercel_kv_token_here